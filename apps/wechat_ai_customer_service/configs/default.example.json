    "enabled": true,
    "window_seconds": 600,
    "threshold": 3,
    "cooldown_seconds": 600
  },
  "product_entity_resolution": {
    "enabled": true,
    "provider": "openai",
    "model_tier": "flash",
    "model": "gpt-5.4",
    "base_url": "https://aiself.vip/v1",
