    "max_catalog_candidates": 8,
    "quality_priority": true,
    "model_routing": {
      "enabled": true,
      "default_tier": "flash",
      "flash_model": "gpt-5.4",
      "pro_model": "gpt-5.4",
      "force_model_tier": "",
